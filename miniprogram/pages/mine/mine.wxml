<view class="page">
  <view class="page-header">
    <view class="avatar-container">
      <view class="avatar">
        <text class="avatar-icon">👤</text>
      </view>
    </view>
    <view class="user-info">
      <view class="nickname-container">
        <view wx:if="{{!editingNickname}}" class="nickname" bindtap="startEditNickname">
          {{nickname}}
          <text class="edit-icon">✏️</text>
        </view>
        <view wx:else class="nickname-edit">
          <input 
            class="nickname-input" 
            value="{{tempNickname}}" 
            placeholder="输入昵称"
            bindinput="onNicknameInput"
            auto-focus
          />
          <view class="nickname-actions">
            <text class="action-btn cancel" bindtap="cancelEdit">取消</text>
            <text class="action-btn confirm" bindtap="saveNickname">保存</text>
          </view>
        </view>
      </view>
      <view class="user-stats">
        <text class="stat-text">累计学习 {{userProfile.totalStudyHours}}小时</text>
        <text class="stat-divider">·</text>
        <text class="stat-text">{{unlockedCount}}/{{achievements.length}}成就</text>
      </view>
    </view>
  </view>

  <view class="content">
    <view class="card">
      <view class="stats-card">
        <view class="stats-row">
          <view class="stat-item">
            <view class="stat-value">{{userProfile.totalStudyDays}}</view>
            <view class="stat-label">学习天数</view>
          </view>
          <view class="stat-item">
            <view class="stat-value">{{userProfile.totalStudyHours}}</view>
            <view class="stat-label">学习小时</view>
          </view>
          <view class="stat-item">
            <view class="stat-value">{{userProfile.longestStreak}}</view>
            <view class="stat-label">最长连续</view>
          </view>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="section-title">
        <text class="section-icon">🏆</text>
        <text class="section-name">成就徽章</text>
      </view>
      <view class="achievements-grid">
        <view 
          wx:for="{{achievements}}" 
          wx:key="id" 
          class="achievement-item {{item.unlocked ? 'unlocked' : ''}}"
        >
          <text class="achievement-icon">{{item.icon}}</text>
          <text class="achievement-name">{{item.title}}</text>
        </view>
      </view>
    </view>

    <view class="menu-list">
      <view 
        wx:for="{{menuItems}}" 
        wx:key="text" 
        class="menu-item"
        data-action="{{item.action}}"
        bindtap="handleMenuClick"
      >
        <text class="menu-icon">{{item.icon}}</text>
        <text class="menu-text">{{item.text}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>
</view>
