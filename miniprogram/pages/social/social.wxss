.page {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 180rpx;
}

.page-header {
  padding: 32rpx;
  padding-top: 48rpx;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  display: block;
}

.page-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.publish-section {
  padding: 0 24rpx;
  margin-top: -24rpx;
}

.publish-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
}

.avatar-small {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.avatar-icon {
  font-size: 32rpx;
}

.publish-input-wrap {
  flex: 1;
  margin-right: 16rpx;
}

.publish-input {
  background: #F1F5F9;
  border-radius: 36rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #1E293B;
}

.type-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #F1F5F9;
  border-radius: 24rpx;
  margin-right: 16rpx;
}

.type-btn .type-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.type-btn .type-text {
  font-size: 24rpx;
  color: #64748B;
}

.publish-btn {
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  border-radius: 24rpx;
  padding: 12rpx 28rpx;
}

.publish-btn text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.type-selector-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.type-selector-content {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.selector-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
  text-align: center;
  margin-bottom: 32rpx;
}

.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.type-item {
  flex: 0 0 calc(33.33% - 14rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #F1F5F9;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.type-item.active {
  background: rgba(99, 102, 241, 0.1);
  border-color: #6366F1;
}

.type-item .type-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.type-item .type-name {
  font-size: 24rpx;
  color: #475569;
}

.today-section {
  padding: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
}

.today-list {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.today-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.today-item:last-child {
  border-bottom: none;
}

.today-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.today-info {
  flex: 1;
}

.today-duration {
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 500;
  display: block;
}

.today-note {
  font-size: 24rpx;
  color: #64748B;
  margin-top: 4rpx;
}

.today-time {
  font-size: 22rpx;
  color: #94A3B8;
}

.posts-section {
  padding: 0 24rpx;
}

.post-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.post-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.post-user-info {
  flex: 1;
}

.post-nickname {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
  display: block;
}

.post-date {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 4rpx;
}

.post-type {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
}

.post-type .type-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.post-type .type-name {
  font-size: 22rpx;
  color: #6366F1;
}

.post-content {
  font-size: 28rpx;
  color: #334155;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.post-duration {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.duration-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.post-duration text:last-child {
  font-size: 24rpx;
  color: #64748B;
}

.post-actions {
  display: flex;
  justify-content: space-around;
  padding-top: 16rpx;
  border-top: 1rpx solid #F1F5F9;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  transition: all 0.3s;
}

.action-item.liked {
  background: rgba(239, 68, 68, 0.1);
}

.action-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.action-text {
  font-size: 26rpx;
  color: #64748B;
}

.action-item.liked .action-text {
  color: #EF4444;
}

.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #64748B;
  display: block;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #94A3B8;
}

.comment-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.comment-modal-content {
  width: 100%;
  max-height: 70vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.modal-close {
  font-size: 32rpx;
  color: #94A3B8;
  padding: 8rpx;
}

.comments-list {
  flex: 1;
  padding: 24rpx;
  max-height: 50vh;
}

.comment-item {
  display: flex;
  margin-bottom: 24rpx;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: #E2E8F0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.comment-avatar text {
  font-size: 28rpx;
}

.comment-body {
  flex: 1;
  background: #F8FAFC;
  border-radius: 0 16rpx 16rpx 16rpx;
  padding: 16rpx;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.comment-nickname {
  font-size: 26rpx;
  font-weight: 600;
  color: #1E293B;
}

.comment-date {
  font-size: 22rpx;
  color: #94A3B8;
}

.comment-content {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.5;
}

.empty-comments {
  text-align: center;
  padding: 40rpx;
  color: #94A3B8;
  font-size: 26rpx;
}

.comment-input-wrap {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F1F5F9;
  background: #FFFFFF;
}

.comment-input {
  flex: 1;
  background: #F1F5F9;
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
}

.send-btn {
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  border-radius: 32rpx;
  padding: 16rpx 32rpx;
  margin-left: 16rpx;
}

.send-btn text {
  font-size: 26rpx;
  color: #FFFFFF;
}

.page {
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}