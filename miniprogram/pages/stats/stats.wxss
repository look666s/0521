.page {
  min-height: 100vh;
  background: #F8FAFC;
  padding-bottom: 200rpx;
}

.page-header {
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  padding: 48rpx 32rpx;
  padding-top: calc(var(--status-bar-height, 44px) + 32rpx);
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.page-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-section {
  padding: 32rpx;
}

.stats-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #6366F1;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #64748B;
}

.calendar-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.nav-btn {
  width: 60rpx;
  height: 60rpx;
  background: #F1F5F9;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 32rpx;
  color: #64748B;
}

.month-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 12rpx;
}

.weekday {
  text-align: center;
  font-size: 24rpx;
  color: #94A3B8;
  padding: 12rpx 0;
}

.calendar-days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.calendar-day {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.calendar-day.empty {
  background: transparent;
}

.calendar-day.today {
  border: 2rpx solid #6366F1;
}

.calendar-day.checked {
  background: rgba(16, 185, 129, 0.1);
}

.calendar-day.notChecked {
  background: #F1F5F9;
}

.day-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.day-number {
  font-size: 24rpx;
  color: #1E293B;
}

.calendar-day.today .day-number {
  color: #6366F1;
  font-weight: 600;
}

.calendar-day.notChecked .day-number {
  color: #94A3B8;
}

.check-dot {
  position: absolute;
  bottom: 4rpx;
  width: 8rpx;
  height: 8rpx;
  background: #10B981;
  border-radius: 4rpx;
}

.week-stats-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.week-stats-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.week-stats-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.week-stats-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.week-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 200rpx;
  padding-top: 32rpx;
}

.week-bar {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
}

.bar-value {
  font-size: 20rpx;
  color: #64748B;
  margin-bottom: 8rpx;
}

.bar-container {
  width: 40rpx;
  height: 140rpx;
  background: #F1F5F9;
  border-radius: 20rpx;
  display: flex;
  align-items: flex-end;
  margin-bottom: 12rpx;
  overflow: hidden;
}

.bar-fill {
  width: 100%;
  background: linear-gradient(180deg, #6366F1 0%, #8B5CF6 100%);
  border-radius: 20rpx;
  transition: height 0.3s ease;
}

.bar-label {
  font-size: 20rpx;
  color: #94A3B8;
}

.month-stats-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.month-stats-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.month-stats-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.month-stats-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.month-stats-row {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.month-stats-row:last-child {
  border-bottom: none;
}

.stat-row-label {
  font-size: 28rpx;
  color: #64748B;
}

.stat-row-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
}
