<view class="page">
  <view class="page-header">
    <view class="page-title">学习统计</view>
    <view class="page-desc">记录你的学习轨迹</view>
  </view>

  <view class="stats-section">
    <view class="stats-card">
      <view class="stats-grid">
        <view class="stat-item">
          <view class="stat-value">{{currentStreak}}</view>
          <view class="stat-label">连续打卡</view>
        </view>
        <view class="stat-item">
          <view class="stat-value">{{longestStreak}}</view>
          <view class="stat-label">最长连续</view>
        </view>
        <view class="stat-item">
          <view class="stat-value">{{completedGoalsPercent}}%</view>
          <view class="stat-label">目标完成率</view>
        </view>
        <view class="stat-item">
          <view class="stat-value">{{unlockedAchievements}}</view>
          <view class="stat-label">已解锁成就</view>
        </view>
      </view>
    </view>

    <view class="calendar-card">
      <view class="calendar-header">
        <view class="nav-btn" bindtap="prevMonth">
          <text class="nav-icon">‹</text>
        </view>
        <view class="month-title">{{currentYear}}年{{currentMonth + 1}}月</view>
        <view class="nav-btn" bindtap="nextMonth">
          <text class="nav-icon">›</text>
        </view>
      </view>
      <view class="calendar-weekdays">
        <view wx:for="{{weekDays}}" wx:key="*this" class="weekday">{{item}}</view>
      </view>
      <view class="calendar-days">
        <view 
          wx:for="{{monthDays}}" 
          wx:key="index" 
          class="calendar-day {{item.fullDate === today ? 'today' : ''}} {{item.checkedIn ? 'checked' : item.date > 0 ? 'notChecked' : 'empty'}}"
        >
          <view wx:if="{{item.date > 0}}" class="day-content">
            <text class="day-number">{{item.date}}</text>
            <view wx:if="{{item.checkedIn}}" class="check-dot"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="week-stats-card">
      <view class="week-stats-header">
        <text class="week-stats-icon">📊</text>
        <text class="week-stats-title">本周学习时长</text>
      </view>
      <view class="week-chart">
        <view wx:for="{{weekData}}" wx:key="date" class="week-bar">
          <text class="bar-value">{{item.duration > 0 ? Math.round(item.duration / 60) + 'h' : '-'}}</text>
          <view class="bar-container">
            <view 
              class="bar-fill" 
              style="height: {{(item.duration / maxWeekDuration) * 100}}%"
            ></view>
          </view>
          <text class="bar-label">{{item.day}}</text>
        </view>
      </view>
    </view>

    <view class="month-stats-card">
      <view class="month-stats-header">
        <text class="month-stats-icon">📈</text>
        <text class="month-stats-title">{{currentMonth + 1}}月统计</text>
      </view>
      <view class="month-stats-row">
        <text class="stat-row-label">本月天数</text>
        <text class="stat-row-value">{{monthStats.totalDays}}天</text>
      </view>
      <view class="month-stats-row">
        <text class="stat-row-label">已打卡</text>
        <text class="stat-row-value">{{monthStats.checkedDays}}天</text>
      </view>
      <view class="month-stats-row">
        <text class="stat-row-label">本月学习</text>
        <text class="stat-row-value">{{formatDuration(monthStats.totalDuration)}}</text>
      </view>
      <view class="month-stats-row">
        <text class="stat-row-label">日均学习</text>
        <text class="stat-row-value">{{formatDuration(monthStats.avgDuration)}}</text>
      </view>
    </view>
  </view>
</view>
