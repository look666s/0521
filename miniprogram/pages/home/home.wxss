.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.header-left {
  flex: 1;
}

.greeting-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1E293B;
  margin-bottom: 8rpx;
}

.greeting-date {
  font-size: 24rpx;
  color: #94A3B8;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 40rpx;
}

.stats-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #6366F1;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #64748B;
}

.divider {
  width: 2rpx;
  background: #E2E8F0;
}

.checkin-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.checkin-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.checkin-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.checkin-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 48rpx;
  background: rgba(245, 158, 11, 0.1);
  color: #F59E0B;
}

.checkin-status.checked {
  background: rgba(16, 185, 129, 0.1);
  color: #10B981;
}

.duration-selector {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.duration-btn {
  flex: 1;
  height: 80rpx;
  background: #F1F5F9;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 8rpx;
  font-size: 28rpx;
  color: #64748B;
}

.duration-btn.active {
  background: #6366F1;
  color: #FFFFFF;
}

.note-input {
  width: 100%;
  height: 120rpx;
  background: #F1F5F9;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #1E293B;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.goal-select-label {
  font-size: 28rpx;
  color: #64748B;
  margin-bottom: 16rpx;
}

.goal-selector {
  margin-bottom: 24rpx;
}

.goal-select-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #F1F5F9;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.goal-select-item.active {
  background: rgba(99, 102, 241, 0.1);
  border-color: #6366F1;
}

.goal-select-name {
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 500;
}

.goal-select-progress {
  font-size: 24rpx;
  color: #6366F1;
  font-weight: 600;
}

.checkin-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkin-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.checkin-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.checked-content {
  text-align: center;
}

.checked-title {
  font-size: 36rpx;
  color: #1E293B;
  margin-bottom: 16rpx;
}

.checked-duration, .checked-note {
  font-size: 28rpx;
  color: #64748B;
  line-height: 1.6;
}

.goal-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.goal-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.goal-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.goal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.goal-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.goal-item:last-child {
  border-bottom: none;
}

.goal-info {
  flex: 1;
}

.goal-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1E293B;
  margin-bottom: 8rpx;
}

.goal-progress-text {
  font-size: 24rpx;
  color: #64748B;
}

.progress-bar {
  width: 200rpx;
  height: 12rpx;
  background: #F1F5F9;
  border-radius: 6rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #6366F1 0%, #8B5CF6 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #6366F1;
  width: 80rpx;
  text-align: right;
}

.empty-goals {
  text-align: center;
  padding: 32rpx 0;
}

.empty-text {
  color: #94A3B8;
  font-size: 28rpx;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 48rpx;
  text-align: center;
}

.modal-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1E293B;
  margin-bottom: 16rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #64748B;
  margin-bottom: 48rpx;
}

.modal-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}
